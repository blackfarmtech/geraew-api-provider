generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["geraew-provider"]
}

model GoogleCredential {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  clientId       String   @map("client_id")
  clientSecret   String   @map("client_secret")
  refreshToken   String   @map("refresh_token")
  quotaProjectId String   @map("quota_project_id")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("google_credentials")
  @@schema("geraew-provider")
}

model RequestLog {
  id             String   @id @default(uuid()) @db.Uuid
  method         String
  url            String
  route          String?
  ip             String?
  userAgent      String?  @map("user_agent")
  requestHeaders Json?    @map("request_headers") @db.JsonB
  requestBody    Json?    @map("request_body") @db.JsonB
  statusCode     Int?     @map("status_code")
  responseBody   Json?    @map("response_body") @db.JsonB
  durationMs     Int?     @map("duration_ms")
  errorMessage   String?  @map("error_message")
  errorStack     String?  @map("error_stack") @db.Text
  handler        String?
  accountId      String?  @map("account_id")
  userId         String?  @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([method, url])
  @@index([statusCode])
  @@index([userId])
  @@map("request_logs")
  @@schema("geraew-provider")
}

model AppLog {
  id           String   @id @default(uuid()) @db.Uuid
  level        String
  context      String?
  message      String   @db.Text
  metadata     Json?    @db.JsonB
  errorStack   String?  @map("error_stack") @db.Text
  requestLogId String?  @map("request_log_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([level])
  @@index([context])
  @@index([requestLogId])
  @@map("app_logs")
  @@schema("geraew-provider")
}

model User {
  id                    String   @id @default(uuid()) @db.Uuid
  email                 String   @unique
  passwordHash          String   @map("password_hash")
  name                  String?
  credits               Int      @default(0)
  stripeCustomerId      String?  @unique @map("stripe_customer_id")
  autoRechargeEnabled   Boolean  @default(false) @map("auto_recharge_enabled")
  autoRechargeThreshold Int      @default(0) @map("auto_recharge_threshold")
  autoRechargeAmount    Int      @default(0) @map("auto_recharge_amount")
  role                  String   @default("user")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  apiKeys            ApiKey[]
  creditTransactions CreditTransaction[]

  @@map("users")
  @@schema("geraew-provider")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  key        String    @unique
  name       String    @default("default")
  active     Boolean   @default(true)
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
  @@map("api_keys")
  @@schema("geraew-provider")
}

model CreditTransaction {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  type                  String
  amount                Int
  balanceAfter          Int      @map("balance_after")
  description           String?
  metadata              Json?    @db.JsonB
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@index([stripePaymentIntentId])
  @@map("credit_transactions")
  @@schema("geraew-provider")
}

model CreditPricing {
  id              String   @id @default(uuid()) @db.Uuid
  model           String
  resolution      String?
  durationSeconds Int?     @map("duration_seconds")
  baseCost        Int      @map("base_cost")
  multipliers     Json?    @db.JsonB
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([model, resolution, durationSeconds])
  @@map("credit_pricing")
  @@schema("geraew-provider")
}

model CreditPackage {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  credits      Int
  priceInCents Int      @map("price_in_cents")
  stripePriceId String? @map("stripe_price_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("credit_packages")
  @@schema("geraew-provider")
}
